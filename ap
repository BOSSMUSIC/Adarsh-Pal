function init(){
  document.getElementById("catBar").innerHTML=CATEGORIES.map(c=>
    `<button class="cat-btn${c==="All"?" active":""}" data-cat="${c}" onclick="setCategory('${c}')">${c}</button>`
  ).join('');
  renderMain();
}

init();
</script>
