  {id:5,name:"Mi Smart Band 8",brand:"Xiaomi",price:3499,mrp:4999,emoji:"⌚",rating:4.3,reviews:18400,category:"Electronics",tags:["smartband","fitness","wearable"]},
  {id:6,name:"Realme Buds Air 5",brand:"Realme",price:2499,mrp:4999,emoji:"🎵",rating:4.2,reviews:9800,category:"Electronics",tags:["earbuds","anc","wireless"]},
  {id:7,name:"Surf Excel Matic Top Load 3kg",brand:"Surf Excel",price:349,mrp:499,emoji:"🧺",rating:4.5,reviews:41200,category:"Grocery",tags:["detergent","washing","cleaning"]},
  {id:8,name:"Tata Salt 1kg",brand:"Tata",price:28,mrp:32,emoji:"🧂",rating:4.6,reviews:91000,category:"Grocery",tags:["salt","kitchen","daily"]},
  {id:9,name:"Aashirvaad Atta 10kg",brand:"Aashirvaad",price:410,mrp:490,emoji:"🌾",rating:4.5,reviews:55000,category:"Grocery",tags:["atta","flour","wheat"]},
  {id:10,name:"Amul Butter 500g",brand:"Amul",price:275,mrp:290,emoji:"🧈",rating:4.7,reviews:72000,category:"Grocery",tags:["butter","dairy","bread"]},
  {id:11,name:"Maggi 2-Minute Noodles 12 pack",brand:"Nestlé",price:149,mrp:180,emoji:"🍜",rating:4.6,reviews:120000,category:"Grocery",tags:["noodles","instant","snack"]},
  {id:12,name:"Dabur Honey 500g",brand:"Dabur",price:199,mrp:249,emoji:"🍯",rating:4.5,reviews:48000,category:"Grocery",tags:["honey","natural","health"]},
  {id:13,name:"Nike Air Max SYSTM Sneakers",brand:"Nike",price:7595,mrp:10995,emoji:"👟",rating:4.3,reviews:3200,category:"Fashion",tags:["shoes","sneakers","sports"]},
  {id:14,name:"Levi's 511 Slim Fit Jeans",brand:"Levi's",price:2999,mrp:5999,emoji:"👖",rating:4.4,reviews:18700,category:"Fashion",tags:["jeans","pants","casual"]},
  {id:15,name:"Peter England Formal Shirt",brand:"Peter England",price:899,mrp:1799,emoji:"👔",rating:4.2,reviews:9400,category:"Fashion",tags:["shirt","formal","office"]},
  {id:16,name:"Puma Sports T-Shirt",brand:"Puma",price:599,mrp:1299,emoji:"👕",rating:4.1,reviews:14200,category:"Fashion",tags:["tshirt","sports","gym"]},
  {id:17,name:"Prestige Iris 750W Mixer Grinder",brand:"Prestige",price:2699,mrp:4500,emoji:"🍹",rating:4.3,reviews:7800,category:"Home",tags:["mixer","grinder","kitchen"]},
  {id:18,name:"Milton Thermosteel Flask 1L",brand:"Milton",price:699,mrp:999,emoji:"🍶",rating:4.5,reviews:32000,category:"Home",tags:["flask","bottle","steel"]},
  {id:19,name:"Pigeon Non-Stick Cookware Set",brand:"Pigeon",price:1299,mrp:2499,emoji:"🍳",rating:4.2,reviews:12100,category:"Home",tags:["cookware","kitchen","non-stick"]},
  {id:20,name:"Philips Air Purifier AC1215",brand:"Philips",price:8999,mrp:14999,emoji:"💨",rating:4.4,reviews:4200,category:"Home",tags:["air purifier","hepa","clean"]},
  {id:21,name:"L'Oreal Paris Serum Foundation",brand:"L'Oreal",price:799,mrp:1299,emoji:"💄",rating:4.1,reviews:23400,category:"Beauty",tags:["makeup","foundation","face"]},
  {id:22,name:"Mamaearth Vitamin C Face Serum",brand:"Mamaearth",price:499,mrp:799,emoji:"✨",rating:4.3,reviews:41000,category:"Beauty",tags:["serum","vitamin c","skincare"]},
  {id:23,name:"Dove Shampoo 650ml",brand:"Dove",price:349,mrp:499,emoji:"🧴",rating:4.4,reviews:65000,category:"Beauty",tags:["shampoo","hair","damage repair"]},
  {id:24,name:"Nivea Moisturizing Cream 200ml",brand:"Nivea",price:199,mrp:299,emoji:"🫙",rating:4.5,reviews:89000,category:"Beauty",tags:["moisturizer","skin","cream"]},
  {id:25,name:"Funskool Pictionary Game",brand:"Funskool",price:599,mrp:999,emoji:"🎲",rating:4.3,reviews:4200,category:"Toys",tags:["game","boardgame","family"]},
  {id:26,name:"Lego Classic Creative Bricks",brand:"Lego",price:2499,mrp:3299,emoji:"🧱",rating:4.7,reviews:8900,category:"Toys",tags:["lego","building","creative"]},
  {id:27,name:"Yoga Mat 6mm Anti-Slip",brand:"Decathlon",price:799,mrp:1299,emoji:"🧘",rating:4.4,reviews:19000,category:"Sports",tags:["yoga","fitness","exercise"]},
  {id:28,name:"Boldfit Protein Shaker 700ml",brand:"Boldfit",price:299,mrp:599,emoji:"🥤",rating:4.2,reviews:28000,category:"Sports",tags:["gym","shaker","protein"]},
  {id:29,name:"Adidas Running Shoes Ultraboost",brand:"Adidas",price:8999,mrp:14999,emoji:"🏃",rating:4.5,reviews:6700,category:"Sports",tags:["running","shoes","boost"]},
  {id:30,name:"SG Cricket Bat Kashmir Willow",brand:"SG",price:1499,mrp:2499,emoji:"🏏",rating:4.3,reviews:3300,category:"Sports",tags:["cricket","bat","kashmir"]},
];

const CATEGORIES = ["All","Electronics","Grocery","Fashion","Home","Beauty","Toys","Sports"];
const OFFERS = [
  {title:"Up to 80% off Electronics",desc:"Limited time deals on phones, laptops & more"},
  {title:"Grocery Saver Pack",desc:"Min 20% off on daily essentials"},
  {title:"Fashion Week Sale",desc:"Top brands starting ₹299"},
  {title:"Dhamaka Saturday",desc:"Extra ₹100 off on cart above ₹999"},
  {title:"Beauty Bonanza",desc:"Buy 2 get 1 free on select skincare"},
];

let cart = {};
let activeCategory = "All";
let searchQuery = "";
let sortBy = "default";

function getDiscount(p,m){return Math.round((1-p/m)*100)}
function stars(r){return"★".repeat(Math.floor(r))+"☆".repeat(5-Math.floor(r))}
function fmt(p){return"₹"+p.toLocaleString("en-IN")}

function addToCart(id){
  cart[id]=(cart[id]||0)+1;
  updateCartBadge();renderCartItems();
  showToast("Added to cart! 🛒");
  renderProducts();
}
function removeFromCart(id){
  if(cart[id]>1)cart[id]--;
  else delete cart[id];
  updateCartBadge();renderCartItems();renderProducts();
}
function deleteFromCart(id){
  delete cart[id];
  updateCartBadge();renderCartItems();renderProducts();
}
function updateCartBadge(){
  document.getElementById("cartBadge").textContent=Object.values(cart).reduce((a,b)=>a+b,0);
}
function showToast(msg){
  const t=document.getElementById("toast");
  t.textContent=msg;t.classList.add("show");
  setTimeout(()=>t.classList.remove("show"),2200);
}
function toggleCart(){
  document.getElementById("cartOverlay").classList.toggle("open");
  renderCartItems();
}
function closeCartOutside(e){
  if(e.target===document.getElementById("cartOverlay"))toggleCart();
}

function renderCartItems(){
  const el=document.getElementById("cartItems");
  const footer=document.getElementById("cartFooter");
  const keys=Object.keys(cart);
  if(!keys.length){
    el.innerHTML='<div class="empty-cart"><div class="ec-icon">🛒</div><p style="font-size:15px;font-weight:500;margin-bottom:6px">Your cart is empty</p><p style="font-size:13px">Add items to get started</p></div>';
    footer.innerHTML='';return;
  }
  let subtotal=0,items=0;
  el.innerHTML=keys.map(id=>{
    const p=PRODUCTS.find(x=>x.id==id);
    const q=cart[id];subtotal+=p.price*q;items+=q;
    return`<div class="cart-item">
      <div class="cart-item-img">${p.emoji}</div>
      <div class="cart-item-info">
        <div class="cart-item-name" title="${p.name}">${p.name}</div>
        <div class="cart-item-price">${fmt(p.price)} <span style="font-size:11px;color:#aaa;font-weight:400">each</span></div>
        <div class="cart-qty">
          <button class="cq-btn" onclick="removeFromCart(${id})">−</button>
          <span style="font-size:13px;font-weight:600">${q}</span>
          <button class="cq-btn" onclick="addToCart(${id})">+</button>
          <span style="font-size:13px;font-weight:600;margin-left:8px">${fmt(p.price*q)}</span>
          <button class="cq-btn" style="margin-left:auto;color:#e63946" onclick="deleteFromCart(${id})" title="Remove"><i class="ti ti-trash" style="font-size:14px"></i></button>
        </div>
      </div>
    </div>`;
  }).join('');
  const delivery=subtotal>=499?0:49;
  footer.innerHTML=`
    <div style="font-size:13px;margin-bottom:8px">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:#666">Subtotal (${items} items)</span><span>${fmt(subtotal)}</span></div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:#666">Delivery</span><span style="color:${delivery===0?'#2d9e4e':'#1a1a1a'}">${delivery===0?"FREE":fmt(delivery)}</span></div>
      ${subtotal>0&&subtotal<499?`<div style="font-size:11px;color:#e63946;margin-top:4px">Add ${fmt(499-subtotal)} more for free delivery</div>`:''}
    </div>
    <div class="cart-total"><span>Total</span><span>${fmt(subtotal+delivery)}</span></div>
    <button class="checkout-btn" onclick="showToast('Redirecting to checkout...')">Proceed to Checkout →</button>`;
}

function handleSearch(q){
  searchQuery=q;
  const grid=document.getElementById("productsGrid");
  if(grid)renderProducts();
}

function setCategory(cat){
  activeCategory=cat;
  document.querySelectorAll(".cat-btn").forEach(b=>b.classList.toggle("active",b.dataset.cat===cat));
  const grid=document.getElementById("productsGrid");
  if(grid)renderProducts();
}

function setSort(s){
  sortBy=s;
  document.querySelectorAll(".filter-chip").forEach(c=>c.classList.toggle("active",c.dataset.sort===s));
  renderProducts();
}

function renderProducts(){
  let filtered=PRODUCTS.filter(p=>{
    const matchCat=activeCategory==="All"||p.category===activeCategory;
    const q=searchQuery.toLowerCase().trim();
    const matchSearch=!q||p.name.toLowerCase().includes(q)||p.brand.toLowerCase().includes(q)||p.tags.some(t=>t.includes(q))||p.category.toLowerCase().includes(q);
    return matchCat&&matchSearch;
  });
  if(sortBy==="price_asc")filtered.sort((a,b)=>a.price-b.price);
  else if(sortBy==="price_desc")filtered.sort((a,b)=>b.price-a.price);
  else if(sortBy==="discount")filtered.sort((a,b)=>getDiscount(b.price,b.mrp)-getDiscount(a.price,a.mrp));
  else if(sortBy==="rating")filtered.sort((a,b)=>b.rating-a.rating);

  const grid=document.getElementById("productsGrid");
  if(!grid)return;
  if(!filtered.length){
    grid.innerHTML='<div class="no-results"><div>🔍</div><p style="font-size:15px;font-weight:500;margin-bottom:6px">No products found</p><p>Try a different search or category</p></div>';
    return;
  }
  grid.innerHTML=filtered.map(p=>{
    const inCart=cart[p.id]||0;
    return`<div class="product-card">
      <div class="product-img">${p.emoji}</div>
      <div class="product-info">
        <div class="product-brand">${p.brand}</div>
        <div class="product-name" title="${p.name}">${p.name}</div>
        <div style="display:flex;align-items:baseline;flex-wrap:wrap;gap:2px;margin-top:4px">
          <span class="product-price">${fmt(p.price)}</span>
          <span class="product-mrp">${fmt(p.mrp)}</span>
          <span class="product-discount">${getDiscount(p.price,p.mrp)}% off</span>
        </div>
        <div class="product-rating">${stars(p.rating)} <span style="color:#aaa;font-size:10px">(${p.reviews.toLocaleString("en-IN")})</span></div>
        ${inCart===0
          ?`<button class="add-btn" onclick="addToCart(${p.id})">+ Add to Cart</button>`
          :`<div class="qty-ctrl">
              <button class="qty-btn" onclick="removeFromCart(${p.id})">−</button>
              <span class="qty-num">${inCart}</span>
              <button class="qty-btn" onclick="addToCart(${p.id})">+</button>
            </div>`
        }
      </div>
    </div>`;
  }).join('');
}

function resetAll(){
  activeCategory="All";searchQuery="";sortBy="default";
  document.getElementById("searchInput").value="";
  document.querySelectorAll(".cat-btn").forEach(b=>b.classList.toggle("active",b.dataset.cat==="All"));
  renderProducts();
  window.scrollTo({top:0,behavior:'smooth'});
}

