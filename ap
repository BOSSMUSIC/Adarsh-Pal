<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShopKart – India's Fastest Online Shopping</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#1a1a1a}
  a{text-decoration:none;color:inherit}

  /* Topbar */
  .topbar{background:#1a1a2e;color:#ccc;padding:6px 24px;font-size:12px;display:flex;justify-content:space-between;align-items:center}

  /* Navbar */
  .navbar{background:#fff;border-bottom:1px solid #e8e8e8;padding:0 24px;display:flex;align-items:center;gap:16px;height:64px;position:sticky;top:0;z-index:100;box-shadow:0 1px 4px rgba(0,0,0,0.06)}
  .logo{font-size:24px;font-weight:700;color:#e63946;letter-spacing:-1px;white-space:nowrap;cursor:pointer}
  .logo span{color:#1a1a2e}
  .search-bar{flex:1;display:flex;max-width:560px;border:2px solid #e63946;border-radius:8px;overflow:hidden}
  .search-bar input{flex:1;border:none;outline:none;padding:10px 16px;font-size:14px;background:#fff;color:#1a1a1a}
  .search-bar button{background:#e63946;color:#fff;border:none;padding:10px 20px;cursor:pointer;font-size:14px;display:flex;align-items:center;gap:6px}
  .search-bar button:hover{background:#c9303b}
  .nav-actions{display:flex;gap:10px;align-items:center;margin-left:auto}
  .nav-btn{background:none;border:1px solid #ddd;border-radius:8px;padding:7px 16px;cursor:pointer;font-size:13px;display:flex;align-items:center;gap:6px;color:#1a1a1a;position:relative;font-family:inherit}
  .nav-btn:hover{background:#f5f5f5;border-color:#bbb}
  .cart-badge{background:#e63946;color:#fff;border-radius:50%;font-size:10px;width:18px;height:18px;display:flex;align-items:center;justify-content:center;position:absolute;top:-7px;right:-7px;font-weight:700}

  /* Category Bar */
  .category-bar{background:#fff;border-bottom:1px solid #e8e8e8;padding:0 24px;display:flex;gap:0;overflow-x:auto;scrollbar-width:none}
  .category-bar::-webkit-scrollbar{display:none}
  .cat-btn{background:none;border:none;padding:12px 16px;cursor:pointer;font-size:13px;color:#555;white-space:nowrap;border-bottom:2px solid transparent;font-family:inherit;transition:color 0.15s}
  .cat-btn:hover,.cat-btn.active{color:#e63946;border-bottom-color:#e63946}

  /* Hero */
  .hero{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);padding:40px 24px;display:flex;align-items:center;justify-content:space-between;gap:20px}
  .hero-text h1{font-size:32px;font-weight:700;color:#fff;line-height:1.3;margin-bottom:10px}
  .hero-text p{color:#aaa;font-size:15px;margin-bottom:20px}
  .hero-cta{background:#e63946;color:#fff;border:none;padding:12px 28px;border-radius:8px;cursor:pointer;font-size:15px;font-weight:600;font-family:inherit;transition:background 0.15s}
  .hero-cta:hover{background:#c9303b}
  .hero-badges{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}
  .badge{background:rgba(255,255,255,0.12);color:#ddd;font-size:12px;padding:5px 12px;border-radius:20px}

  /* Offer Strip */
  .offers-strip{display:flex;gap:12px;overflow-x:auto;padding:20px 24px;scrollbar-width:none}
  .offers-strip::-webkit-scrollbar{display:none}
  .offer-card{min-width:210px;background:#fff4f5;border:1px solid #ffd0d3;border-radius:12px;padding:14px 18px;flex-shrink:0;cursor:pointer;transition:transform 0.15s}
  .offer-card:hover{transform:translateY(-2px)}
  .offer-card h4{font-size:13px;font-weight:600;color:#e63946;margin-bottom:4px}
  .offer-card p{font-size:12px;color:#666}

  /* Sections */
  .section{padding:24px 24px}
  .section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
  .section-header h2{font-size:20px;font-weight:600}

  /* Categories Grid */
  .categories-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:12px}
  .cat-card{background:#fff;border:1px solid #e8e8e8;border-radius:12px;padding:16px 10px;text-align:center;cursor:pointer;transition:border-color 0.15s,transform 0.15s}
  .cat-card:hover{border-color:#e63946;transform:translateY(-2px)}
  .cat-card .cat-icon{font-size:32px;margin-bottom:8px}
  .cat-card p{font-size:12px;color:#555;font-weight:500}

  /* Products Grid */
  .products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:14px}
  .product-card{background:#fff;border:1px solid #e8e8e8;border-radius:12px;overflow:hidden;cursor:pointer;transition:transform 0.15s,box-shadow 0.15s}
  .product-card:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,0.1)}
  .product-img{height:150px;display:flex;align-items:center;justify-content:center;font-size:58px;background:#f8f8f8}
  .product-info{padding:12px}
  .product-brand{font-size:11px;color:#888;margin-bottom:3px;text-transform:uppercase;letter-spacing:0.5px}
  .product-name{font-size:13px;font-weight:500;margin-bottom:8px;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;min-height:36px}
  .product-price{font-size:16px;font-weight:700;color:#e63946}
  .product-mrp{font-size:11px;color:#aaa;text-decoration:line-through;margin-left:4px}
  .product-discount{font-size:11px;color:#2d9e4e;font-weight:600;margin-left:4px}
  .product-rating{font-size:11px;color:#f4a52b;margin-top:6px}
  .add-btn{width:100%;background:#fff;border:1.5px solid #e63946;color:#e63946;border-radius:8px;padding:7px;cursor:pointer;font-size:12px;font-weight:600;margin-top:10px;font-family:inherit;transition:background 0.15s,color 0.15s}
  .add-btn:hover{background:#e63946;color:#fff}
  .qty-ctrl{display:flex;align-items:center;justify-content:space-between;border:1.5px solid #e63946;border-radius:8px;margin-top:10px;overflow:hidden}
  .qty-btn{background:none;border:none;padding:5px 12px;cursor:pointer;font-size:18px;color:#e63946;font-weight:700;font-family:inherit;transition:background 0.15s}
  .qty-btn:hover{background:#fff0f1}
  .qty-num{font-size:14px;font-weight:600;color:#1a1a1a}

  /* Cart Overlay */
  .overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:200;display:none;align-items:flex-start;justify-content:flex-end}
  .overlay.open{display:flex}
  .cart-panel{background:#fff;width:360px;height:100vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:-4px 0 20px rgba(0,0,0,0.15)}
  .cart-header{padding:18px 20px;border-bottom:1px solid #e8e8e8;display:flex;justify-content:space-between;align-items:center}
  .cart-header h3{font-size:17px;font-weight:600}
  .close-btn{background:none;border:none;cursor:pointer;font-size:22px;color:#888;font-family:inherit;line-height:1}
  .close-btn:hover{color:#1a1a1a}
  .cart-items{flex:1;overflow-y:auto;padding:16px}
  .cart-item{display:flex;gap:12px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #f0f0f0}
  .cart-item-img{font-size:34px;width:54px;height:54px;background:#f8f8f8;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .cart-item-info{flex:1;min-width:0}
  .cart-item-name{font-size:13px;font-weight:500;margin-bottom:3px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
  .cart-item-price{font-size:14px;color:#e63946;font-weight:700}
  .cart-qty{display:flex;align-items:center;gap:8px;margin-top:8px}
  .cq-btn{background:#f5f5f5;border:1px solid #ddd;border-radius:6px;width:26px;height:26px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;color:#1a1a1a;font-family:inherit}
  .cq-btn:hover{background:#e8e8e8}
  .cart-footer{padding:16px 20px;border-top:1px solid #e8e8e8;background:#fafafa}
  .cart-total{display:flex;justify-content:space-between;font-weight:700;font-size:16px;margin-bottom:6px}
  .checkout-btn{width:100%;background:#e63946;color:#fff;border:none;border-radius:8px;padding:13px;cursor:pointer;font-size:15px;font-weight:600;font-family:inherit;margin-top:12px;transition:background 0.15s}
  .checkout-btn:hover{background:#c9303b}
  .empty-cart{text-align:center;padding:48px 20px;color:#aaa}
  .empty-cart .ec-icon{font-size:52px;margin-bottom:14px}

  /* Toast */
  .toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:#1a1a2e;color:#fff;padding:11px 24px;border-radius:8px;font-size:13px;z-index:400;opacity:0;transition:opacity 0.3s;pointer-events:none;white-space:nowrap}
  .toast.show{opacity:1}

  /* Filter Bar */
  .filter-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;align-items:center}
  .filter-chip{background:#fff;border:1px solid #ddd;border-radius:20px;padding:5px 14px;font-size:12px;cursor:pointer;font-family:inherit;color:#555;transition:all 0.15s}
  .filter-chip:hover,.filter-chip.active{background:#e63946;color:#fff;border-color:#e63946}
  .filter-label{font-size:12px;color:#888;font-weight:500}

  /* Footer */
  .footer{background:#1a1a2e;color:#aaa;padding:32px 24px;margin-top:40px}
  .footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:24px;margin-bottom:24px}
  .footer h4{color:#fff;font-size:14px;font-weight:600;margin-bottom:10px}
  .footer p,.footer a{font-size:13px;color:#aaa;display:block;margin-bottom:6px;cursor:pointer}
  .footer a:hover{color:#fff}
  .footer-bottom{border-top:1px solid #2e2e4e;padding-top:20px;text-align:center;font-size:12px}

  /* No results */
  .no-results{grid-column:1/-1;text-align:center;padding:48px 20px;color:#aaa}
  .no-results div{font-size:48px;margin-bottom:14px}

  @media(max-width:600px){
    .topbar span:last-child{display:none}
    .hero-text h1{font-size:22px}
    .products-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr))}
    .cart-panel{width:100vw}
    .navbar{padding:0 12px}
    .section{padding:16px 12px}
  }
</style>
</head>
<body>

<div class="topbar">
  <span>🚀 Free delivery on orders above ₹499</span>
  <span>⚡ 10-minute express delivery available in select cities</span>
</div>

<nav class="navbar">
  <div class="logo" onclick="resetAll()">Shop<span>Kart</span></div>
  <div class="search-bar">
    <input type="text" id="searchInput" placeholder="Search for products, brands and more..." oninput="handleSearch(this.value)">
    <button onclick="handleSearch(document.getElementById('searchInput').value)"><i class="ti ti-search"></i> Search</button>
  </div>
  <div class="nav-actions">
    <button class="nav-btn" onclick="toggleCart()">
      <i class="ti ti-shopping-cart"></i> Cart
      <span class="cart-badge" id="cartBadge">0</span>
    </button>
    <button class="nav-btn" onclick="showToast('Sign in coming soon!')"><i class="ti ti-user"></i> Sign in</button>
  </div>
</nav>

<div class="category-bar" id="catBar"></div>

<div id="mainContent"></div>

<div class="overlay" id="cartOverlay" onclick="closeCartOutside(event)">
  <div class="cart-panel" onclick="event.stopPropagation()">
    <div class="cart-header">
      <h3>🛒 Your Cart</h3>
      <button class="close-btn" onclick="toggleCart()"><i class="ti ti-x"></i></button>
    </div>
    <div class="cart-items" id="cartItems"></div>
    <div class="cart-footer" id="cartFooter"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const PRODUCTS = [
  {id:1,name:"OnePlus Nord CE 4 Lite 5G",brand:"OnePlus",price:19999,mrp:24999,emoji:"📱",rating:4.3,reviews:2841,category:"Electronics",tags:["mobile","phone","5g"]},
  {id:2,name:"boAt Airdopes 141 TWS Earbuds",brand:"boAt",price:1299,mrp:4990,emoji:"🎧",rating:4.1,reviews:89032,category:"Electronics",tags:["earphones","audio","bluetooth"]},
  {id:3,name:'Samsung 43" Crystal 4K Smart TV',brand:"Samsung",price:29990,mrp:54900,emoji:"📺",rating:4.4,reviews:5120,category:"Electronics",tags:["tv","television","4k"]},
